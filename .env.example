# ─── Servidor ───────────────────────────────────────────────
# Port intern on escolta l'aplicació (8200 està lliure al servidor)
PORT=8200

# ─── Motor d'IA (Claude Code, ja instal·lat i autenticat al contenidor) ──
# Ordre per invocar el CLI (normalment no cal tocar)
CLAUDE_CMD=claude
# Model: 'opus' fa acudits més enginyosos (per defecte); 'sonnet' és més ràpid però més tòpic.
CLAUDE_MODEL=opus
# Temps màxim (segons) per generar un acudit (opus pot trigar més)
AI_TIMEOUT=180
# Quants acudits ja existents s'envien a Claude com a context (perquè no els repeteixi)
MAX_CONTEXT_JOKES=300

# ─── Dades ──────────────────────────────────────────────────
# Carpeta de dades persistents (en producció, el volum de Dokploy muntat a /app/data)
DATA_DIR=./data
